<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">
    <LinearLayout
        android:id="@+id/icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <ImageView
            android:id="@+id/imageview2"
            android:focusable="false"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/djgamingvip"
            android:scaleType="fitXY" />
        <ImageView
            android:id="@+id/imageview3"
            android:focusable="false"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginBottom="25dp"
            android:src="@drawable/close1"
            android:scaleType="fitCenter"
            android:translationX="-5.0dp" />
    </LinearLayout>
    <LinearLayout
        android:id="@+id/linear1"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:src="@drawable/edittext_bg"
        android:background="#070707"
        android:orientation="vertical">
        <LinearLayout
            android:id="@+id/linear2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/textview1"
                android:focusable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="DJ GAMING VIP"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />
            <TextView
                android:id="@+id/textview2"
                android:focusable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="5dp"
                android:paddingTop="4dp"
                android:paddingRight="8dp"
                android:paddingBottom="4dp"
                android:text="PANEL"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#00FF00"
                android:layout_weight="1" />
            <ImageView
                android:id="@+id/imageview1"
                android:focusable="false"
                android:layout_width="19dp"
                android:layout_height="19dp"
                android:src="@drawable/close1"
                android:scaleType="fitCenter" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/linear3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal|center_vertical"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/textview3"
                android:focusable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text="Aimbot"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#00FF00" />
            <TextView
                android:id="@+id/textview4"
                android:focusable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="10dp"
                android:paddingTop="8dp"
                android:paddingRight="10dp"
                android:paddingBottom="8dp"
                android:text="Location"
                android:textSize="12sp"
                android:textColor="#9E9E9E" />
            <TextView
                android:id="@+id/textview5"
                android:focusable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text="Settings"
                android:textSize="12sp"
                android:textColor="#9E9E9E" />
        </LinearLayout>
        <ScrollView
            android:id="@+id/vscroll1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:id="@+id/linear4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout
                    android:id="@+id/l1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingRight="3dp"
                    android:paddingLeft="3dp"
                    android:layout_marginBottom="8dp"
                    android:orientation="vertical">
                    <Switch
                        android:id="@+id/switch1"
                        android:focusable="false"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingLeft="3dp"
                        android:paddingTop="10dp"
                        android:paddingRight="3dp"
                        android:paddingBottom="10dp"
                        android:gravity="left|center_vertical"
                        android:text="Aimbot 95%"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                    <Switch
                        android:id="@+id/switch2"
                        android:focusable="false"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingLeft="3dp"
                        android:paddingTop="10dp"
                        android:paddingRight="3dp"
                        android:paddingBottom="10dp"
                        android:gravity="left|center_vertical"
                        android:text="Aim Scope"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                    <Switch
                        android:id="@+id/switch3"
                        android:focusable="false"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingLeft="3dp"
                        android:paddingTop="10dp"
                        android:paddingRight="3dp"
                        android:paddingBottom="10dp"
                        android:gravity="left|center_vertical"
                        android:text="Aim Lock"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                    <Switch
                        android:id="@+id/switch4"
                        android:focusable="false"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingLeft="3dp"
                        android:paddingTop="10dp"
                        android:paddingRight="3dp"
                        android:paddingBottom="10dp"
                        android:gravity="left|center_vertical"
                        android:text="Aim Tiro"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/l2"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingRight="3dp"
                    android:paddingLeft="3dp"
                    android:layout_marginBottom="8dp"
                    android:orientation="vertical">
                    <Switch
                        android:id="@+id/switch5"
                        android:focusable="false"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingLeft="3dp"
                        android:paddingTop="10dp"
                        android:paddingRight="3dp"
                        android:paddingBottom="10dp"
                        android:gravity="left|center_vertical"
                        android:text="Esp Crosshair"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                    <Switch
                        android:id="@+id/switch6"
                        android:focusable="false"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingLeft="3dp"
                        android:paddingTop="10dp"
                        android:paddingRight="3dp"
                        android:paddingBottom="10dp"
                        android:gravity="left|center_vertical"
                        android:text="Esp Granada"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                    <Switch
                        android:id="@+id/switch7"
                        android:focusable="false"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingLeft="3dp"
                        android:paddingTop="10dp"
                        android:paddingRight="3dp"
                        android:paddingBottom="10dp"
                        android:gravity="left|center_vertical"
                        android:text="Esp Name"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                    <Switch
                        android:id="@+id/switch8"
                        android:focusable="false"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingLeft="3dp"
                        android:paddingTop="10dp"
                        android:paddingRight="3dp"
                        android:paddingBottom="10dp"
                        android:gravity="left|center_vertical"
                        android:text="Esp Lazer"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/l3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingRight="3dp"
                    android:paddingLeft="3dp"
                    android:layout_marginBottom="8dp"
                    android:orientation="vertical">
                    <Switch
                        android:id="@+id/switch9"
                        android:focusable="false"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingLeft="3dp"
                        android:paddingTop="10dp"
                        android:paddingRight="3dp"
                        android:paddingBottom="10dp"
                        android:gravity="left|center_vertical"
                        android:text="Anti Cheat"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                    <Switch
                        android:id="@+id/switch10"
                        android:focusable="false"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingLeft="3dp"
                        android:paddingTop="10dp"
                        android:paddingRight="3dp"
                        android:paddingBottom="10dp"
                        android:gravity="left|center_vertical"
                        android:text="Anti Report"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                    <Switch
                        android:id="@+id/switch11"
                        android:focusable="false"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingLeft="3dp"
                        android:paddingTop="10dp"
                        android:paddingRight="3dp"
                        android:paddingBottom="10dp"
                        android:gravity="left|center_vertical"
                        android:text="Anti Bypass"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                    <Switch
                        android:id="@+id/switch12"
                        android:focusable="false"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingLeft="3dp"
                        android:paddingTop="10dp"
                        android:paddingRight="3dp"
                        android:paddingBottom="10dp"
                        android:gravity="left|center_vertical"
                        android:text="Anti Record"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</LinearLayout>
