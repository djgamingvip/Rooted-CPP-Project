<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Collapsed State (Icon) -->
    <RelativeLayout
        android:id="@+id/icon"
        android:layout_width="65dp"
        android:layout_height="65dp"
        android:layout_margin="5dp">

        <ImageView
            android:id="@+id/imageview1"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_centerInParent="true"
            android:src="@drawable/djgamingvip"
            android:scaleType="fitCenter"
            android:elevation="5dp" />

    </RelativeLayout>

    <!-- Expanded State (Main Panel) -->
    <LinearLayout
        android:id="@+id/linear1"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:background="@drawable/floating_bg"
        android:orientation="vertical"
        android:padding="2dp"
        android:elevation="8dp">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/linear2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_corners"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="5dp"
            android:layout_margin="2dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/textview1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DJ GAMING"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />
                <TextView
                    android:id="@+id/textview2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="VIP"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FF3B3B" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/linear_minimize"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:paddingLeft="3dp"
                android:paddingRight="3dp"
                android:layout_marginRight="3dp">

                <ImageView
                    android:id="@+id/imageview2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_remove_white"
                    app:tint="#88FFFFFF"
                    android:scaleType="fitCenter" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/linear_close"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:paddingLeft="3dp"
                android:paddingRight="3dp">

                <ImageView
                    android:id="@+id/imageview3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/close1"
                    app:tint="#88FFFFFF"
                    android:scaleType="fitCenter" />
            </LinearLayout>
        </LinearLayout>

        <!-- Tabs / Categories -->
        <LinearLayout
            android:id="@+id/linear3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingVertical="6dp"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/textview3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="AIMBOT"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#FF0000" />

            <View
                android:layout_width="1dp"
                android:layout_height="12dp"
                android:background="#33FFFFFF" />

            <TextView
                android:id="@+id/textview4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="VISUAL"
                android:textSize="10sp"
                android:textColor="#9E9E9E" />

            <View
                android:layout_width="1dp"
                android:layout_height="12dp"
                android:background="#33FFFFFF" />

            <TextView
                android:id="@+id/textview5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="SYSTEM"
                android:textSize="10sp"
                android:textColor="#9E9E9E" />
        </LinearLayout>

        <!-- Content Area -->
        <ScrollView
            android:id="@+id/vscroll1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/linear4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- Aimbot Group -->
                <LinearLayout
                    android:id="@+id/l1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <Switch
                        android:id="@+id/switch1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Aimbot 95%"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:background="@drawable/floating_item_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginBottom="8dp"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                    <Switch
                        android:id="@+id/switch2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Fly Up"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:background="@drawable/floating_item_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginBottom="8dp"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                    <Switch
                        android:id="@+id/switch3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Fly Map"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:background="@drawable/floating_item_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginBottom="8dp"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                    <Switch
                        android:id="@+id/switch4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Football Hack"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:background="@drawable/floating_item_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginBottom="8dp"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                </LinearLayout>

                <!-- Visual Group -->
                <LinearLayout
                    android:id="@+id/l2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <Switch
                        android:id="@+id/switch5"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Esp Crosshair"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:background="@drawable/floating_item_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginBottom="8dp"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                    <Switch
                        android:id="@+id/switch6"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Esp Granada"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:background="@drawable/floating_item_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginBottom="8dp"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                    <Switch
                        android:id="@+id/switch7"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Esp Name"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:background="@drawable/floating_item_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginBottom="8dp"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                    <Switch
                        android:id="@+id/switch8"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Esp Lazer"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:background="@drawable/floating_item_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginBottom="8dp"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                </LinearLayout>

                <!-- System Group -->
                <LinearLayout
                    android:id="@+id/l3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <Switch
                        android:id="@+id/switch9"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Anti Cheat"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:background="@drawable/floating_item_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginBottom="8dp"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                    <Switch
                        android:id="@+id/switch10"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Anti Report"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:background="@drawable/floating_item_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginBottom="8dp"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                    <Switch
                        android:id="@+id/switch11"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Anti Bypass"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:background="@drawable/floating_item_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginBottom="8dp"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                    <Switch
                        android:id="@+id/switch12"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Anti Record"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:background="@drawable/floating_item_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginBottom="8dp"
                        android:thumb="@drawable/thumb"
                        android:track="@drawable/track" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <!-- Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="6dp"
            android:text="SECURED BY DJ GAMING"
            android:textColor="#33FFFFFF"
            android:textSize="8sp"
            android:letterSpacing="0.1" />
    </LinearLayout>
</LinearLayout>
